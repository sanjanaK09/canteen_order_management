[MASTER]
django-settings-module=canteen_project.settings
load-plugins=pylint_django
init-hook='import sys; sys.path.append(".")'
extension-pkg-allow-list=Pillow

[MESSAGES CONTROL]
disable=
    missing-docstring,
    too-few-public-methods,
    duplicate-code,
    too-many-arguments,
    C0302,
    C0304,

[FORMAT]
max-line-length=100

[DESIGN]
max-attributes=7
max-arguments=5

[VARIABLES]
ignored-argument-names=_.*

[LOGGING]
logging-format-style=new

[TYPECHECK]
ignored-classes=models,forms

[BASIC]
good-names=i,j,k,ex,Run,_
